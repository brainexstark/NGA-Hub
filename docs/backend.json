
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user profile within the STARK-B Legacy network.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ageGroup": { "type": "string", "enum": ["under-10", "10-16", "16-plus"] },
        "dob": { "type": "string", "format": "date" },
        "profilePicture": { "type": "string", "format": "uri" },
        "phoneNumber": { "type": "string" },
        "premiumFeatures": { "type": "boolean" },
        "isBreached": { "type": "boolean" },
        "channelId": { "type": "string" },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "disciplesCount": { "type": "number" },
        "timerNotifications": { "type": "boolean" },
        "darkTheme": { "type": "boolean" },
        "language": { "type": "string" },
        "locationNotifications": { "type": "boolean" },
        "country": { "type": "string" },
        "privacyLevel": { "type": "string", "enum": ["public", "private"] }
      },
      "required": ["uid", "displayName", "email", "ageGroup"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post in the community feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "story", "reel"] },
        "mediaUrl": { "type": "string", "format": "uri" },
        "caption": { "type": "string" },
        "title": { "type": "string" },
        "ageGroup": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "mediaUrl", "ageGroup", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "text", "createdAt"]
    },
    "VideoEntry": {
      "title": "VideoEntry",
      "description": "A record in the user's personal video bank.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" },
        "duration": { "type": "string" },
        "source": { "type": "string", "enum": ["deposit", "record", "save"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "videoUrl", "createdAt"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "Daily attendance record for a learning session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "activeSeconds": { "type": "number" },
        "platform": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["title", "startTime", "activeSeconds", "date"]
    },
    "LearningSubject": {
      "title": "LearningSubject",
      "description": "A subject with lessons and completion targets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "total": { "type": "number" },
        "completed": { "type": "number" },
        "lessons": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "total", "completed"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profile data."
    },
    "/users/{userId}/videos/{videoId}": {
      "schema": { "$ref": "#/backend/entities/VideoEntry" },
      "description": "The user's personal video bank records."
    },
    "/users/{userId}/attendance/{attendanceId}": {
      "schema": { "$ref": "#/backend/entities/AttendanceRecord" },
      "description": "Daily learning attendance and active time logs."
    },
    "/users/{userId}/learning_profile/subjects": {
      "schema": { "type": "object", "properties": { "subjects": { "type": "array", "items": { "$ref": "#/backend/entities/LearningSubject" } } } },
      "description": "User customized learning subjects and mission targets."
    },
    "/global_curriculum/{subjectId}/lessons/{lessonId}": {
      "schema": { "type": "object", "properties": { "title": { "type": "string" }, "url": { "type": "string" }, "duration": { "type": "string" } } },
      "description": "Admin broadcast lessons available globally."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/backend/entities/Post" },
      "description": "Public social media posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/backend/entities/Comment" },
      "description": "Comments on community posts."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/Message" },
      "description": "Private or community chat messages."
    }
  }
}
